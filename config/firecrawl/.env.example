# Firecrawl self-hosted configuration
# Copy to extras/firecrawl/.env and adjust as needed.

PORT=3002
HOST=0.0.0.0

# Number of parallel workers for the crawl job queue.
NUM_WORKERS_PER_QUEUE=4

# Block images and media in Playwright to speed up scraping.
BLOCK_MEDIA=true

# Optional: HTTP proxy for IP rotation (leave unset for direct connections).
# PROXY_SERVER=http://proxy.example.com:8080
# PROXY_USERNAME=
# PROXY_PASSWORD=

# Optional: OpenAI key for AI-powered extract endpoint (not required for basic scraping).
# OPENAI_API_KEY=<your-openrouter-key>
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# MODEL_NAME=openai/gpt-4o-mini
